# Version control ignores

# Python Backend Ignores
backend/__pycache__/
backend/*.pyc
backend/*.pyo
backend/*.pyd
backend/.pytest_cache/
backend/.env
backend/*.db
backend/careerpilot.db

# Frontend Ignores
frontend/node_modules/
frontend/dist/
frontend/.oxlintrc.json

# IDEs & System Ignores
.idea/
.vscode/
*.swp
*.log
.DS_Store
Thumbs.db
